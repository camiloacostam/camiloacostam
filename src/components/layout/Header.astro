---
import { t, getLang, getAlternatePath } from '../../i18n/utils';
const lang = getLang(Astro.currentLocale);
const tr   = t(lang);
const prefix    = lang === 'en' ? '/en' : '';
const altPath   = getAlternatePath(Astro.url.pathname, lang);
const altLabel  = lang === 'es' ? 'EN' : 'ES';
---
<header>
  <nav class="navbar">
    <a href={prefix + '/'} class="logo">Camilo Acosta</a>

    <ul class="nav-links">
      <li><a href={prefix + '/#servicios'}>{tr.nav.services}</a></li>
      <li><a href={prefix + '/proyectos'}>{tr.nav.projects}</a></li>
      <li><a href={prefix + '/#sobre-mi'}>{tr.nav.about}</a></li>
      <li><a href={prefix + '/blog'}>{tr.nav.blog}</a></li>
      <li><a href={prefix + '/#contacto'}>{tr.nav.contact}</a></li>
    </ul>

    <div class="navbar-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <!-- Sun: shown in dark mode -->
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <!-- Moon: shown in light mode -->
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a href={altPath} class="lang-switcher">{altLabel}</a>
      <button class="cta-btn" onclick="Calendly.initPopupWidget({url:'https://calendly.com/hello-camiloacosta/30min'});return false;">{tr.nav.cta}</button>
    </div>

    <button class="hamburger" id="menu-toggle" aria-label="Abrir menú">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    <ul>
      <li><a href={prefix + '/#servicios'}>{tr.nav.services}</a></li>
      <li><a href={prefix + '/proyectos'}>{tr.nav.projects}</a></li>
      <li><a href={prefix + '/#sobre-mi'}>{tr.nav.about}</a></li>
      <li><a href={prefix + '/blog'}>{tr.nav.blog}</a></li>
      <li><a href={prefix + '/#contacto'}>{tr.nav.contact}</a></li>
    </ul>
    <div class="mobile-bottom">
      <button class="cta-btn-mobile" onclick="Calendly.initPopupWidget({url:'https://calendly.com/hello-camiloacosta/30min'});return false;">{tr.nav.cta}</button>
      <a href={altPath} class="lang-switcher-mobile">{altLabel}</a>
      <button class="theme-toggle theme-toggle--mobile" id="theme-toggle-mobile" aria-label="Cambiar tema">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // ── Mobile menu ──────────────────────────────────────
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => menu.classList.remove('open'))
  );

  // ── Theme toggle ─────────────────────────────────────
  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  function handleToggle() {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  }

  document.getElementById('theme-toggle')?.addEventListener('click', handleToggle);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', handleToggle);

  // Sync with OS preference changes (no saved preference)
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
    if (!localStorage.getItem('theme')) {
      applyTheme(e.matches ? 'dark' : 'light');
    }
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--border-default);
  }

  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 clamp(20px, 5.5vw, 80px);
    max-width: 1440px;
    margin: 0 auto;
  }

  .logo {
    font-family: 'Dancing Script', cursive;
    font-size: 26px;
    font-weight: 700;
    color: var(--blue-primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text-primary); }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 6px;
    border: 1.5px solid var(--border-default);
    color: var(--text-secondary);
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .theme-toggle:hover { border-color: var(--blue-primary); color: var(--blue-primary); }

  /* Show sun in dark mode, moon in light mode */
  :root:not([data-theme="dark"]) .icon-sun { display: none; }
  [data-theme="dark"] .icon-moon { display: none; }

  .lang-switcher {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    border: 1.5px solid var(--border-default);
    border-radius: 6px;
    padding: 5px 10px;
    transition: border-color 0.2s, color 0.2s;
    letter-spacing: 0.5px;
  }
  .lang-switcher:hover { border-color: var(--blue-primary); color: var(--blue-primary); }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--blue-primary);
    color: var(--white);
    font-size: 14px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    transition: opacity 0.2s;
  }

  .cta-btn:hover { opacity: 0.85; }

  /* Hamburger: hidden on desktop */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    padding: 4px;
  }

  /* Mobile drawer: hidden by default on ALL sizes */
  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 20px;
    background: var(--white);
    border-top: 1px solid transparent;
    border-bottom: 1px solid transparent;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease, border-color 0.35s ease;
    /* Flota sobre la página sin empujar el contenido */
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  /* Only show when toggled on mobile */
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu ul a {
    display: block;
    padding: 12px 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-default);
    transition: color 0.2s;
  }

  .mobile-menu ul a:hover { color: var(--text-primary); }

  .mobile-bottom {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }

  .theme-toggle--mobile {
    border: 1.5px solid var(--border-default);
    border-radius: 6px;
    padding: 13px;
    height: auto;
    width: auto;
    color: var(--text-secondary);
  }

  .lang-switcher-mobile {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    border: 1.5px solid var(--border-default);
    border-radius: 6px;
    padding: 13px 16px;
    white-space: nowrap;
  }

  .cta-btn-mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    margin-top: 0;
    background: var(--blue-primary);
    color: var(--white);
    font-size: 15px;
    font-weight: 600;
    padding: 14px;
    border-radius: var(--radius-sm);
  }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 900px) {
    .navbar { height: 56px; }
    .logo   { font-size: 16px; }

    /* Hide desktop nav + CTA */
    .nav-links { display: none; }
    .cta-btn   { display: none; }

    /* Show hamburger */
    .hamburger { display: flex; }

    /* Drawer slides down when JS adds .open class */
    .mobile-menu.open {
      max-height: 400px;
      padding: 16px 20px 20px;
      border-top-color: var(--border-default);
      border-bottom-color: var(--border-default);
    }
  }
</style>
