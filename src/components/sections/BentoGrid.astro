---
import { t, getLang } from '../../i18n/utils';
const lang = getLang(Astro.currentLocale);
const tr = t(lang);
---

<svg style="display:none">
  <symbol id="icon-palette" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/>
    <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/>
    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
  </symbol>
  <symbol id="icon-layers" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="12,2 2,7 12,12 22,7 12,2"/><polyline points="2,17 12,22 22,17"/><polyline points="2,12 12,17 22,12"/>
  </symbol>
  <symbol id="icon-zap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="13,2 3,14 12,14 11,22 21,10 12,10 13,2"/>
  </symbol>
  <symbol id="icon-code" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/>
  </symbol>
  <symbol id="icon-map-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
  </symbol>
  <symbol id="icon-server" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
    <line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
  </symbol>
  <symbol id="bento-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </symbol>
  <symbol id="bento-linkedin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
    <rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
  </symbol>
  <symbol id="bento-github" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
  </symbol>
</svg>

<section class="bento-section" id="servicios">
  <div class="bento-inner">
    <h2 class="section-title">{tr.bento.title}</h2>

    <!-- ── Desktop: 3-column bento ── -->
    <div class="bento-grid">

      <div class="bento-col">
        <div class="card card--blue card--tall">
          <svg class="icon icon--white icon--lg"><use href="#icon-palette"/></svg>
          <div>
            <h3 class="card-title card-title--white">{tr.bento.uiux.title}</h3>
            <p class="card-desc card-desc--white">{tr.bento.uiux.desc}</p>
          </div>
        </div>
        <div class="card">
          <svg class="icon"><use href="#icon-layers"/></svg>
          <h4 class="card-title">{tr.bento.stack.title}</h4>
          <div class="tag-row">
            <span class="tag">React</span><span class="tag">Next.js</span>
            <span class="tag">Tailwind</span><span class="tag">Figma</span>
            <span class="tag">Node.js</span><span class="tag">Astro</span>
          </div>
        </div>
        <div class="card">
          <svg class="icon"><use href="#icon-zap"/></svg>
          <h4 class="card-title">{tr.bento.delivery.title}</h4>
          <p class="card-desc">{tr.bento.delivery.desc}</p>
        </div>
      </div>

      <div class="bento-col">
        <div class="card">
          <svg class="icon"><use href="#icon-code"/></svg>
          <h4 class="card-title">{tr.bento.frontend.title}</h4>
          <p class="card-desc">{tr.bento.frontend.desc}</p>
          <div class="tag-row">
            <span class="tag">React</span><span class="tag">Next.js</span>
            <span class="tag">Tailwind</span>
          </div>
        </div>
        <div class="card card--center">
          <svg class="icon"><use href="#icon-map-pin"/></svg>
          <h4 class="card-title" style="text-align:center">{tr.bento.location}</h4>
        </div>
        <div class="card card--blue card--center">
          <span class="stat-num">20+</span>
          <span class="stat-lbl">{tr.bento.clients}</span>
        </div>
        <div class="card card--center">
          <span class="social-label-text">{tr.bento.social}</span>
          <div class="social-row">
            <a href="https://wa.me/573007458843" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="WhatsApp">
              <svg class="icon"><use href="#bento-whatsapp"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/camilo-acosta-m/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="LinkedIn">
              <svg class="icon"><use href="#bento-linkedin"/></svg>
            </a>
            <a href="https://github.com/camiloacostam" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="GitHub">
              <svg class="icon"><use href="#bento-github"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="bento-col">
        <div class="card">
          <svg class="icon"><use href="#icon-server"/></svg>
          <h4 class="card-title">{tr.bento.fullstack.title}</h4>
          <p class="card-desc">{tr.bento.fullstack.desc}</p>
          <div class="tag-row">
            <span class="tag">Node.js</span><span class="tag">Databases</span>
          </div>
        </div>
        <div class="card card--center">
          <span class="stat-num stat-num--blue">15+</span>
          <span class="stat-lbl stat-lbl--gray">{tr.bento.delivered}</span>
        </div>
        <div class="card card--center">
          <div class="avail-row">
            <span class="avail-dot"></span>
            <span class="avail-text">{tr.bento.available}</span>
          </div>
        </div>
        <div class="card card--center">
          <span class="stat-num stat-num--blue">5+</span>
          <span class="stat-lbl stat-lbl--gray">{tr.bento.experience}</span>
        </div>
      </div>

    </div>

    <!-- ── Mobile: stats + 2-col cards ── -->
    <div class="mobile-layout">
      <div class="m-stats">
        <div class="m-stat m-stat--blue">
          <span class="m-stat-num">15+</span>
          <span class="m-stat-lbl">{tr.bento.mProjects}</span>
        </div>
        <div class="m-stat">
          <span class="m-stat-num m-stat-num--blue">20+</span>
          <span class="m-stat-lbl m-stat-lbl--gray">{tr.bento.mClients}</span>
        </div>
        <div class="m-stat">
          <span class="m-stat-num m-stat-num--blue">5+</span>
          <span class="m-stat-lbl m-stat-lbl--gray">{tr.bento.mYears}</span>
        </div>
      </div>
      <div class="m-cards">
        <div class="card card--blue">
          <svg class="icon icon--white"><use href="#icon-palette"/></svg>
          <h4 class="card-title card-title--white">{tr.bento.uiux.title}</h4>
          <p class="card-desc card-desc--white">{tr.bento.uiux.desc}</p>
        </div>
        <div class="card">
          <svg class="icon"><use href="#icon-zap"/></svg>
          <h4 class="card-title">{tr.bento.delivery.title}</h4>
          <p class="card-desc">{tr.bento.delivery.desc}</p>
        </div>
        <div class="card">
          <svg class="icon"><use href="#icon-code"/></svg>
          <h4 class="card-title">{tr.bento.frontend.title}</h4>
          <p class="card-desc">{tr.bento.frontend.desc}</p>
        </div>
        <div class="card">
          <svg class="icon"><use href="#icon-server"/></svg>
          <h4 class="card-title">{tr.bento.fullstack.title}</h4>
          <p class="card-desc">{tr.bento.fullstack.desc}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .bento-section { background: var(--blue-light); }

  .bento-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 60px clamp(24px, 4.2vw, 60px);
    max-width: 1440px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 28px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }

  /* ── Desktop 3-col bento (no tablet intermediate) ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .bento-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mobile-layout { display: none; }

  /* Card base */
  .card {
    background: var(--white);
    border: 1.5px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card--blue   { background: var(--blue-primary); border-color: transparent; }
  .card--tall   { justify-content: flex-end; min-height: 220px; }
  .card--center { align-items: center; justify-content: center; text-align: center; }

  .icon        { width: 24px; height: 24px; color: var(--blue-primary); flex-shrink: 0; }
  .icon--white { color: var(--white); }
  .icon--lg    { width: 32px; height: 32px; }

  .card-title        { font-size: 17px; font-weight: 600; color: var(--text-primary); }
  .card-title--white { color: var(--white); }

  .card-desc        { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }
  .card-desc--white { color: rgba(255,255,255,0.8); }

  .tag-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag     { font-size: 13px; font-weight: 500; color: var(--blue-primary); background: var(--blue-light); border-radius: 6px; padding: 4px 10px; }

  .stat-num        { font-size: 30px; font-weight: 700; color: var(--white); }
  .stat-num--blue  { color: var(--blue-primary); }
  .stat-lbl        { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.8); }
  .stat-lbl--gray  { color: var(--text-secondary); }

  .avail-row  { display: flex; align-items: center; gap: 8px; }
  .avail-dot  { width: 10px; height: 10px; border-radius: 50%; background: var(--green-dot); flex-shrink: 0; }
  .avail-text { font-size: 14px; font-weight: 600; color: var(--text-primary); }

  /* Social card */
  .social-label-text { font-size: 13px; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.5px; }
  .social-row { display: flex; align-items: center; gap: 12px; }
  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--border-default);
    color: var(--text-secondary);
    transition: border-color 0.2s, color 0.2s;
  }
  .social-btn:hover { border-color: var(--blue-primary); color: var(--blue-primary); }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .bento-inner   { padding: 40px 24px; gap: 16px; }
    .section-title { font-size: 22px; }
    .bento-grid    { display: none; }
    .mobile-layout { display: flex; flex-direction: column; gap: 12px; }

    .m-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }

    .m-stat {
      background: var(--white);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      padding: 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
    }

    .m-stat--blue { background: var(--blue-primary); border-color: transparent; }

    .m-stat-num       { font-size: 24px; font-weight: 700; color: var(--white); }
    .m-stat-num--blue { color: var(--blue-primary); }
    .m-stat-lbl       { font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.8); }
    .m-stat-lbl--gray { color: var(--text-secondary); }

    .m-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

    .card { border-radius: var(--radius-md); padding: 16px; gap: 8px; }
    .card-title { font-size: 14px; }
    .card-desc  { font-size: 12px; }
    .icon       { width: 20px; height: 20px; }
    .icon--white{ width: 22px; height: 22px; }
  }
</style>
