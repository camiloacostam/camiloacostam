---
import { projects } from '../../data/projects';
import { t, getLang } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr   = t(lang);

const featured = projects
  .filter(p => p.featured)
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
---
<section class="projects-section" id="proyectos">
  <div class="projects-inner">

    <div class="section-header">
      <h2 class="section-title">{tr.projects.title}</h2>
      <a href="/proyectos" class="see-all">{tr.projects.seeAll}</a>
    </div>

    {featured.length === 0 ? (
      <div class="empty-state">
        <p class="empty-title">{tr.projects.emptyTitle}</p>
        <p class="empty-desc">{tr.projects.emptyDesc}</p>
      </div>
    ) : (
      <div class="slider-wrap">

        <!-- Flecha izquierda -->
        <button class="arrow arrow--prev" id="proj-prev" aria-label={tr.projects.prev} disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15,18 9,12 15,6"/>
          </svg>
        </button>

        <div class="slider-viewport">
          <div class="slider-track" id="proj-track">
            {featured.map(p => (
              <article class="slide">
                <div
                  class="slide-cover"
                  style={p.cover ? `background-image:url('${p.cover}')` : ''}
                >
                  {!p.cover && <span class="cover-placeholder">{tr.projects.cover}</span>}
                </div>
                <div class="slide-details">
                  <span class="project-cat">{p.category.toUpperCase()}</span>
                  <h3 class="project-name">{p.title}</h3>
                  <p class="project-desc">{p.description}</p>
                  <div class="tech-row">
                    {p.tech.map(t => <span class="tech-tag">{t}</span>)}
                  </div>
                  {p.link && (
                    <a href={p.link} class="project-link">{tr.projects.viewProject}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Flecha derecha -->
        <button class="arrow arrow--next" id="proj-next" aria-label={tr.projects.next}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9,18 15,12 9,6"/>
          </svg>
        </button>

      </div>
    )}

    <!-- Dots -->
    {featured.length > 1 && (
      <div class="slider-dots" id="proj-dots">
        {featured.map((_, i) => (
          <button class={`dot ${i === 0 ? 'dot--active' : ''}`} data-index={i} aria-label={`Ir al proyecto ${i + 1}`}></button>
        ))}
      </div>
    )}

  </div>
</section>

<script>
  const track   = document.getElementById('proj-track') as HTMLElement | null;
  const btnPrev = document.getElementById('proj-prev') as HTMLButtonElement | null;
  const btnNext = document.getElementById('proj-next') as HTMLButtonElement | null;
  const dots    = document.querySelectorAll<HTMLButtonElement>('#proj-dots .dot');
  const total   = track?.children.length ?? 0;

  let current = 0;

  function goTo(index: number) {
    current = index;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;

    // Flechas
    if (btnPrev) btnPrev.disabled = current === 0;
    if (btnNext) btnNext.disabled = current === total - 1;

    // Dots
    dots.forEach((d, i) => d.classList.toggle('dot--active', i === current));
  }

  btnPrev?.addEventListener('click', () => goTo(current - 1));
  btnNext?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.dataset.index))));

  // Estado inicial
  goTo(0);
</script>

<style>
  .projects-section { background: var(--white); }

  .projects-inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 80px clamp(24px, 5.5vw, 80px);
    max-width: 1440px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .section-title { font-size: 28px; font-weight: 600; color: var(--text-primary); letter-spacing: -0.5px; }
  .see-all { font-size: 14px; font-weight: 500; color: var(--blue-primary); transition: opacity 0.2s; }
  .see-all:hover { opacity: 0.75; }

  /* Empty */
  .empty-state { text-align: center; padding: 60px 24px; background: var(--blue-light); border-radius: var(--radius-lg); }
  .empty-title { font-size: 17px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
  .empty-desc  { font-size: 14px; color: var(--text-secondary); }

  /* ── Slider ── */
  .slider-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .slider-viewport {
    flex: 1;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-default);
  }

  .slider-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Slide card ── */
  .slide {
    display: flex;
    width: 100%;
    flex-shrink: 0;
    min-height: 380px;
  }

  .slide-cover {
    width: 480px;
    background: var(--blue-light);
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cover-placeholder { font-size: 13px; color: var(--text-secondary); }

  .slide-details {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    padding: 48px 40px;
    flex: 1;
    min-width: 0;
  }

  .project-cat  { font-size: 11px; font-weight: 600; color: var(--text-secondary); letter-spacing: 1.5px; text-transform: uppercase; }
  .project-name { font-size: 24px; font-weight: 700; color: var(--text-primary); line-height: 1.2; }
  .project-desc { font-size: 15px; color: var(--text-secondary); line-height: 1.6; }

  .tech-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .tech-tag { font-size: 12px; font-weight: 500; color: var(--blue-primary); background: var(--blue-light); border-radius: var(--radius-sm); padding: 5px 10px; }

  .project-link { font-size: 14px; font-weight: 600; color: var(--blue-primary); align-self: flex-start; transition: opacity 0.2s; margin-top: 8px; }
  .project-link:hover { opacity: 0.75; }

  /* ── Flechas ── */
  .arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--border-default);
    background: var(--white);
    color: var(--text-primary);
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.2s, color 0.2s, opacity 0.2s;
  }

  .arrow:hover:not(:disabled) {
    border-color: var(--blue-primary);
    color: var(--blue-primary);
  }

  .arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* ── Dots ── */
  .slider-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: var(--border-default);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.25s;
  }

  .dot--active { width: 24px; background: var(--blue-primary); }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .projects-inner { padding: 40px 24px; gap: 20px; }
    .section-title  { font-size: 22px; }

    .slider-wrap { gap: 10px; }

    .slide { flex-direction: column; min-height: unset; }

    .slide-cover {
      width: 100%;
      height: 200px;
      flex-shrink: 0;
    }

    .slide-details { padding: 20px; gap: 12px; }

    .project-name { font-size: 18px; }
    .project-desc { font-size: 13px; }

    .arrow { width: 36px; height: 36px; }
    .arrow svg { width: 16px; height: 16px; }
  }
</style>
