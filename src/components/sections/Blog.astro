---
import { getCollection } from 'astro:content';
import { t, getLang } from '../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr   = t(lang);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = allPosts.slice(0, 3);

const badgeColor: Record<string, string> = {
  IA:         'ia',
  Marketing:  'marketing',
  Desarrollo: 'desarrollo',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short', year: 'numeric' });
}
---
<section class="blog-section" id="blog">
  <div class="blog-inner">

    <div class="blog-header">
      <h2 class="section-title">{tr.blog.title}</h2>
      {posts.length > 0 && (
        <a href="/blog" class="blog-cta">
          <span class="cta-long">{tr.blog.seeAllLong}</span>
          <span class="cta-short">{tr.blog.seeAllShort}</span>
        </a>
      )}
    </div>

    {posts.length === 0 ? (
      <!-- Empty state -->
      <div class="empty-state">
        <p class="empty-icon">✍️</p>
        <p class="empty-title">{tr.blog.emptyTitle}</p>
        <p class="empty-desc">{tr.blog.emptyDesc}</p>
        <a href="/blog" class="empty-cta">{tr.blog.emptyLink}</a>
      </div>
    ) : (
      <>
        <!-- Filters: desktop only -->
        <div class="filter-row">
          {tr.blog.filters.map((f: string, i: number) => (
            <button class={`filter-btn ${i === 0 ? 'filter-btn--active' : ''}`}>{f}</button>
          ))}
        </div>

        <!-- Desktop grid -->
        <div class="blog-grid">
          {posts.map(post => (
            <article class="blog-card">
              <span class={`badge badge--${badgeColor[post.data.badge]}`}>{post.data.badge}</span>
              <div class="card-img" style={post.data.cover ? `background-image:url('${post.data.cover}')` : ''}></div>
              <h3 class="card-title">{post.data.title}</h3>
              <p class="card-excerpt">{post.data.excerpt}</p>
              <div class="card-footer">
                <span class="card-date">{formatDate(post.data.date)}</span>
                <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="card-read">{tr.blog.readMore}</a>
              </div>
            </article>
          ))}
        </div>

        <!-- Mobile slider -->
        <div class="blog-slider">
          <div class="slider-track">
            {posts.map(post => (
              <article class="slide-card">
                <div class="slide-img" style={post.data.cover ? `background-image:url('${post.data.cover}')` : ''}></div>
                <span class={`badge badge--${badgeColor[post.data.badge]}`}>{post.data.badge}</span>
                <h3 class="slide-title">{post.data.title}</h3>
                <div class="card-footer">
                  <span class="card-date">{formatDate(post.data.date)}</span>
                  <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="card-read">{tr.blog.readMore}</a>
                </div>
              </article>
            ))}
          </div>
          <div class="slider-dots">
            {posts.map((_, i) => (
              <span class={`dot ${i === 0 ? 'dot--active' : ''}`}></span>
            ))}
          </div>
        </div>
      </>
    )}

  </div>
</section>

<script>
  const track = document.querySelector('.slider-track') as HTMLElement | null;
  const dots  = document.querySelectorAll<HTMLElement>('.slider-dots .dot');

  track?.addEventListener('scroll', () => {
    const index = Math.round(track.scrollLeft / track.clientWidth);
    dots.forEach((d, i) => d.classList.toggle('dot--active', i === index));
  }, { passive: true });
</script>

<style>
  .blog-section { background: var(--white); }

  .blog-inner {
    display: flex;
    flex-direction: column;
    gap: 48px;
    padding: 80px clamp(24px, 5.5vw, 80px);
    max-width: 1440px;
    margin: 0 auto;
  }

  .blog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .section-title { font-size: 32px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.5px; }

  .blog-cta { font-size: 15px; font-weight: 500; color: var(--blue-primary); transition: opacity 0.2s; }
  .blog-cta:hover { opacity: 0.75; }
  .cta-short { display: none; }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 60px 24px;
    text-align: center;
    background: var(--blue-light);
    border-radius: var(--radius-lg);
  }

  .empty-icon  { font-size: 36px; margin: 0; }
  .empty-title { font-size: 18px; font-weight: 600; color: var(--text-primary); }
  .empty-desc  { font-size: 15px; color: var(--text-secondary); max-width: 420px; line-height: 1.5; }
  .empty-cta   { font-size: 14px; font-weight: 600; color: var(--blue-primary); margin-top: 4px; transition: opacity 0.2s; }
  .empty-cta:hover { opacity: 0.75; }

  /* Filters */
  .filter-row { display: flex; align-items: center; gap: 8px; }

  .filter-btn {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid var(--border-default);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn--active { background: var(--blue-primary); color: var(--white); border-color: var(--blue-primary); }
  .filter-btn:not(.filter-btn--active):hover { border-color: var(--blue-primary); color: var(--blue-primary); }

  /* Desktop grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .blog-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
    transform: translateY(-2px);
  }

  .badge { display: inline-block; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; align-self: flex-start; }
  .badge--ia         { background: var(--badge-ia-bg);         color: var(--badge-ia-text); }
  .badge--marketing  { background: var(--badge-marketing-bg);  color: var(--badge-marketing-text); }
  .badge--desarrollo { background: var(--badge-desarrollo-bg); color: var(--badge-desarrollo-text); }

  .card-img { width: 100%; height: 180px; border-radius: var(--radius-sm); background: var(--blue-light); background-size: cover; background-position: center; }

  .card-title  { font-size: 18px; font-weight: 700; color: var(--text-primary); line-height: 1.3; }
  .card-excerpt{ font-size: 14px; color: var(--text-secondary); line-height: 1.6; flex: 1; }

  .card-footer { display: flex; align-items: center; justify-content: space-between; }
  .card-date   { font-size: 13px; color: var(--text-secondary); }
  .card-read   { font-size: 13px; font-weight: 500; color: var(--blue-primary); transition: opacity 0.2s; }
  .card-read:hover { opacity: 0.75; }

  /* Mobile slider: hidden on desktop */
  .blog-slider { display: none; }

  /* ── Mobile ─────────────────────────────── */
  @media (max-width: 900px) {
    .blog-inner  { padding: 40px 0; gap: 16px; }
    .blog-header { padding: 0 24px; }
    .section-title { font-size: 22px; }
    .cta-long  { display: none; }
    .cta-short { display: inline; }
    .blog-cta  { font-size: 14px; }

    .empty-state { margin: 0 24px; }

    .filter-row { display: none; }
    .blog-grid  { display: none; }

    .blog-slider {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .slider-track {
      display: flex;
      gap: 0;
      overflow-x: auto;
      padding: 4px 0;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .slider-track::-webkit-scrollbar { display: none; }

    .slide-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px 24px;
      border: none;
      border-radius: 0;
      background: var(--white);
      width: 100vw;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .slide-img   { width: 100%; height: 140px; border-radius: var(--radius-sm); background: var(--blue-light); background-size: cover; background-position: center; }
    .slide-title { font-size: 15px; font-weight: 700; color: var(--text-primary); line-height: 1.3; }

    .slider-dots {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 0 24px;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 3px;
      background: var(--border-default);
      transition: all 0.2s;
    }

    .dot--active { width: 20px; background: var(--blue-primary); }
  }
</style>
