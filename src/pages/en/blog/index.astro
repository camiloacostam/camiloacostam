---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { t, getLang } from '../../../i18n/utils';

const lang = getLang(Astro.currentLocale);
const tr   = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const badgeColors: Record<string, string> = {
  IA:         'badge--ia',
  Marketing:  'badge--marketing',
  Desarrollo: 'badge--desarrollo',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('es-CO', { day: 'numeric', month: 'short', year: 'numeric' });
}
---
<Layout title={tr.blogPage.title} description={tr.blogPage.desc}>
  <section class="blog-page">
    <div class="blog-page-inner">

      <div class="page-header">
        <h1 class="page-title">Blog</h1>
        <p class="page-sub">{tr.blogPage.desc}</p>
      </div>

      {posts.length === 0 ? (
        <div class="empty-state">
          <span class="empty-icon">✍️</span>
          <p class="empty-title">{tr.blogPage.emptyTitle}</p>
          <p class="empty-desc">{tr.blogPage.emptyDesc}</p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/en/blog/${post.id.replace(/\.mdx?$/, '')}`} class="post-card">
              <div class="post-cover" style={post.data.cover ? `background-image:url('${post.data.cover}')` : ''}></div>
              <div class="post-body">
                <span class={`badge ${badgeColors[post.data.badge]}`}>{post.data.badge}</span>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-excerpt">{post.data.excerpt}</p>
                <div class="post-footer">
                  <span class="post-date">{formatDate(post.data.date)}</span>
                  <span class="post-read">{tr.blogPage.back}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>
</Layout>

<style>
  .blog-page { background: var(--white); min-height: 60vh; }

  .blog-page-inner {
    display: flex;
    flex-direction: column;
    gap: 48px;
    padding: 80px clamp(24px, 5.5vw, 80px);
    max-width: 1440px;
    margin: 0 auto;
  }

  .page-header { display: flex; flex-direction: column; gap: 12px; }
  .page-title  { font-size: 40px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.5px; }
  .page-sub    { font-size: 18px; color: var(--text-secondary); }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon  { font-size: 40px; }
  .empty-title { font-size: 20px; font-weight: 600; color: var(--text-primary); }
  .empty-desc  { font-size: 15px; color: var(--text-secondary); }

  /* Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .post-cover {
    width: 100%;
    height: 200px;
    background: var(--blue-light);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    flex: 1;
  }

  .badge { display: inline-block; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; align-self: flex-start; }
  .badge--ia         { background: #EEEDFE; color: #3C3489; }
  .badge--marketing  { background: #E1F5EE; color: #085041; }
  .badge--desarrollo { background: #FAECE7; color: #712B13; }

  .post-title   { font-size: 18px; font-weight: 700; color: var(--text-primary); line-height: 1.3; }
  .post-excerpt { font-size: 14px; color: var(--text-secondary); line-height: 1.6; flex: 1; }

  .post-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .post-date   { font-size: 13px; color: var(--text-secondary); }
  .post-read   { font-size: 13px; font-weight: 500; color: var(--blue-primary); }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .blog-page-inner { padding: 40px 24px; gap: 32px; }
    .page-title { font-size: 28px; }
    .page-sub   { font-size: 15px; }
    .posts-grid { grid-template-columns: 1fr; gap: 16px; }
    .post-cover { height: 160px; }
    .post-body  { padding: 16px; }
    .post-title { font-size: 16px; }
  }
</style>
